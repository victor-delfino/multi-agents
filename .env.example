# ===========================================
# Multi-Agents Project - Environment Variables
# ===========================================
# Copie este arquivo para .env e preencha com suas chaves
# cp .env.example .env

# Groq API Key (obrigatória)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Modelo padrão (opcional - padrão: llama-3.3-70b-versatile)
# Opções: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
MODEL_NAME=llama-3.3-70b-versatile

# Temperatura padrão (opcional - padrão: 0.7)
# 0.0 = determinístico, 1.0 = criativo
MODEL_TEMPERATURE=0.7
